# =============================================
# AMBIENTE (development | production)
# =============================================
ENVIRONMENT=development

# =============================================
# BANCO DE DADOS
# development: SQLite (automático)
# production:  postgresql://user:pass@host:5432/dbname
# =============================================
DATABASE_URL=sqlite:///./rh_system.db

# =============================================
# SEGURANÇA JWT
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================
SECRET_KEY=troque-esta-chave-por-uma-segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# CRIPTOGRAFIA FERNET (CPF, RG, conta bancária)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================
FERNET_KEY=troque-esta-chave-por-uma-gerada

# =============================================
# EMAIL (reset de senha)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
EMAIL_FROM=seu-email@gmail.com

# =============================================
# VERSÃO DO APP (auto-update)
# =============================================
APP_VERSION=1.0.0

# =============================================
# CORS (origens permitidas)
# =============================================
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
